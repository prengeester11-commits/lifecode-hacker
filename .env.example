# ── OpenAI ──────────────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 토스페이먼츠 ─────────────────────────────────
# https://developers.tosspayments.com 에서 발급
# 테스트 키: test_ck_..., 실서비스 키: live_ck_...
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Gmail ───────────────────────────────────────
# 발송에 사용할 Gmail 주소
GMAIL_ADDRESS=your-email@gmail.com
# Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호 에서 발급 (16자리)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Flask ───────────────────────────────────────
FLASK_SECRET_KEY=lifecoder-hacker-secret-change-this
FLASK_DEBUG=false
PORT=5000
